# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# Session secret - CHANGE THIS TO A LONG RANDOM STRING IN PRODUCTION
SESSION_SECRET=super-long-random-secret-here-change-me-in-production

# Email configuration
# === LOCAL DEVELOPMENT (recommended) ===
# 1. Go to https://mailtrap.io (free)
# 2. Create a new Inbox
# 3. Open the inbox → "SMTP" or "Integrations" tab
# 4. Copy ONLY the SMTP "Username" and "Password" (long strings, e.g. starting with 1a2b...)
#    IMPORTANT: These are NOT your mailtrap.io login credentials.
MAILTRAP_USER=
MAILTRAP_PASS=

# If you leave MAILTRAP blank, it falls back to Ethereal (test only).
# You will see a preview URL in the server console.

# For PRODUCTION use Resend (recommended) or other
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Fallback / other SMTP (not recommended for dev)
# EMAIL_HOST=
# EMAIL_PORT=
# EMAIL_USER=
# EMAIL_PASS=

# Default sender (change for production)
EMAIL_FROM="Pick Your Path Stories <no-reply@pypstories.com>"

# Payment with Stripe (use test keys for now)
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret   # for production webhooks

# For local development with Stripe webhooks, use Stripe CLI:
# stripe listen --forward-to localhost:3000/api/webhook

# Domain for email links
APP_URL=http://localhost:3000
# For production: https://pypstories.com
